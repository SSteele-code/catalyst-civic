# Catalyst Civic — local configuration
# Copy this file to .env and set values for your environment.
# Scripts read these at runtime via os.getenv().

# Root of your local data store (agenda PDFs, transcripts, pipeline outputs).
# All _Sources, _Modes, and _Schema sub-paths are derived from this.
CC_DATA_ROOT=C:\CatalystCivic

# PostgreSQL connection
PG_HOST=localhost
PG_PORT=5432
PG_DB=catalyst_civic
PG_USER=postgres
PG_PASS=postgres
